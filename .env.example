# Application Environment Configuration
# Copy this file to .env and update with your values

# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/qr-paint-system?retryWrites=true&w=majority

# Optional: If using a separate API domain for the client
# REACT_APP_API_URL=https://your-api-domain.com

# Security (Optional)
# JWT_SECRET=your-secret-key-here
# API_KEY=your-api-key-here

# Do not commit actual secret values into source control.
